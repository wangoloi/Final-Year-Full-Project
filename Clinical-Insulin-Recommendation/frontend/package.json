{
  "name": "glucosense-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite",
    "dev:api": "node --max-old-space-size=1536 ./scripts/start-api.cjs",
    "dev:fast": "node --max-old-space-size=1536 ./node_modules/concurrently/dist/bin/concurrently.js -k -n api,web -c blue,cyan \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:full": "node --max-old-space-size=1536 ./node_modules/concurrently/dist/bin/concurrently.js -k -n api,web -c blue,cyan \"npm run dev:api\" \"node --max-old-space-size=1536 ./scripts/start-web.cjs\"",
    "start": "npm run dev:fast",
    "start:full": "npm run dev:full",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.0",
    "vite": "^5.1.0",
    "wait-on": "^8.0.1"
  }
}
