# GlucoSense frontend (Vite)
# Integrated dev: Meal Plan Vite runs on 5175 (see scripts/start-integrated.ps1). Match this URL here.
VITE_MEAL_PLAN_URL=http://localhost:5175
# Dev: omit VITE_MEAL_PLAN_API_URL — SSO uses same-origin /api/auth (Vite proxies to Meal API on :8001).
# Optional: MEAL_PLAN_API_PROXY=http://127.0.0.1:8001  (proxy target in vite.config.js; default is 8001)
# Production: set VITE_MEAL_PLAN_API_URL to the public Meal Plan API origin if different from the portal.
