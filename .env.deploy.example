# Copy to .env.deploy and use: docker compose --env-file .env.deploy up --build
#
# Production: use long random values for JWT_SECRET and GLUCOSENSE_EMBED_KEY.
# GlucoSense frontend embed secret must equal GLUCOSENSE_EMBED_KEY (baked at image build).

JWT_SECRET=replace-with-long-random-string-min-32-chars
GLUCOSENSE_EMBED_KEY=replace-with-long-random-string

# Browser-facing URLs (must match docker-compose port mappings)
PUBLIC_GLUCOSENSE_URL=http://localhost:8080
PUBLIC_MEAL_WEB_URL=http://localhost:8082
PUBLIC_MEAL_API_URL=http://localhost:8081

# Optional: comma-separated extra CORS origins for Meal Plan API, e.g. https://app.yourdomain.com
CORS_EXTRA_ORIGINS=

# Optional: require X-API-Key on GlucoSense clinical API
# GLUCOSENSE_API_KEY=
