# Copy to .env and adjust. Loaded from backend/ and parent repo.

# Typesense (optional). If TYPESENSE_HOST is unset, food search uses SQLite + RapidFuzz only.
# Start Typesense: docker compose -f docker-compose.typesense.yml up -d
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8108
# TYPESENSE_PROTOCOL=http
# TYPESENSE_API_KEY=xyz

# Chatbot: RAG (Chroma + sentence-transformers) + LLM. Without a key/host, replies stay rule-based.
# OPENAI_API_KEY=sk-...
# CHATBOT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# Or local Ollama (pull a model first: ollama pull llama3.2):
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# CHATBOT_USE_LEGACY_ONLY=false
# CHATBOT_HISTORY_MAX=20
# CHATBOT_TOPIC_NLP=true
# CHATBOT_TOPIC_THRESHOLD=0.38
# CHATBOT_TOPIC_MAXSIM_FALLBACK=0.30
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHROMA_PERSIST_DIR=./instance/chroma_nutrition
